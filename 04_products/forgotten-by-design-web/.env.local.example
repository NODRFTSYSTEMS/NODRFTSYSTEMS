# Sanity — get these from sanity.io/manage after creating your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token — create a "read-only" token in sanity.io/manage
SANITY_API_TOKEN=your_read_token_here

# Kit (ConvertKit) — get from kit.com API settings
KIT_API_KEY=your_kit_api_key_here
KIT_FORM_ID=your_kit_form_id_here

# Public site URL — used in sitemap and OG tags
NEXT_PUBLIC_SITE_URL=https://forgottenbydesign.com
